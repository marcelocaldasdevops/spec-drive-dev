{
  "info": {
    "name": "E-Commerce API Full Coverage",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Fail)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:3001/api/v1/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"test@test.com\",\"password\":\"wrong\"}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Response is not 500 (handled error or 400/401/404)\", function () { pm.expect(pm.response.code).to.be.oneOf([400, 401, 404]); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/api/v1/products",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/api/v1/categories",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "categories"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 or 404\", function () { pm.expect(pm.response.code).to.be.oneOf([200, 404]); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart (Requires Auth)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/api/v1/cart",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "cart"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 401 Unauthorized\", function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/api/v1/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "orders"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Route is valid (not 404 router level)\", function () { pm.expect(pm.response.code).to.not.eql(404); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3001/api/v1/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1", "users"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Route is valid\", function () { pm.expect(pm.response.code).to.not.eql(404); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
